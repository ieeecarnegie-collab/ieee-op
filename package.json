{
  "name": "ieee-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run db:setup && next dev",
    "build": "npm run db:setup && next build",
    "start": "next start",
    "lint": "eslint",
    "db:push": "drizzle-kit push",
